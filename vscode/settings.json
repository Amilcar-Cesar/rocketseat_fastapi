{
    "files.exclude": {
        "**/__pycache__": true,
        "**/__pycache__/**": true,
        "**/.pytest_cache": true,
        "**/.pytest_cache/**": true,
        "**/*.pyc": {
            "when": "$(basename).py"
        }
    },
    "search.exclude": {
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/*.pyc": true
    },
    "files.watcherExclude": {
        "**/__pycache__/**": true,
        "**/.pytest_cache/**": true,
        "**/*.pyc": true
    }
}